# Flask
FLASK_ENV=development
SECRET_KEY=replace-with-a-local-random-value
API_HOST=127.0.0.1
API_PORT=5000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite is the default for the MVP. MySQL can be configured later.
DATABASE_URL=sqlite:///remote_sensing.db

# Files and models are referenced by project-relative paths.
UPLOAD_DIR=uploads
MODEL_DIR=models/weights
MAX_UPLOAD_MB=20
MAX_IMAGE_PIXELS=40000000

# Inference defaults
INFERENCE_DEVICE=auto
YOLO_MODEL_PATH=models/weights/yolo-default.pt
